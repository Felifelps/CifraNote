#:kivy 1.9.0

<MainPage>:
    canvas.before:
        Color:
            rgba: .24, .24, .24, 1
        Rectangle:
            size: self.size
            pos: self.pos
    OptionsBar:
        size_hint: 1, .06
        pos_hint: {"top": 1, "center_x": .5}
    
    FileArea:
        size_hint: 1, .94
        pos_hint: {"y": 0, "center_x": .5}
    
    
    