#:kivy 1.9.0
#:include view\optionsbar.kv
#:include view\filearea.kv

<MainPage>:
    canvas.before:
        Color:
            rgba: 0, 0, 0, 1
        Rectangle:
            size: self.size
            pos: self.pos
    OptionsBar:
        size_hint: 1, .06
        pos_hint: {"top": 1, "center_x": .5}
    
    FileArea:
        size_hint: 1, .94
        pos_hint: {"y": 0, "center_x": .5}
    