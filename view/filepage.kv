#:kivy 1.9.0

<FilePage@RelativeLayout>:
    title: ""
    content: ""
    canvas:
        Color:
            rgba: .25, .25, .25, 1
        Rectangle:
            pos: 0, 0
            size: self.width, self.height
    Label:
        text: root.title
        size_hint: 1, .08
        pos_hint: {"center_x": .5, "top": 1}
        font_size: "20sp"

    TextInput:
        multiline: True
        text: root.content
        size_hint: .98, .92
        pos_hint: {"center_x": .5, "y": 0}
        font_size: "20sp"
        background_color: 0, 0, 0, 0
        foreground_color: 1, 1, 1, 1
        hint_text: "Digite a cifra aqui"
