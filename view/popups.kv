#:kivy 1.9.0

<FileNamePopup>:
    size_hint: .8, .2
    pos_hint: {"center_x": .5, "center_y": .5}
    save: _save
    cancel: _cancel
    textinput: _textinput
    canvas.before:
        Color:
            rgba: 0, 0, 0, .5
        Rectangle:
            pos: dp(-1000), dp(-1000)
            size: dp(2000), dp(2000)
        Color:
            rgba: .2, .2, .2, 1
        RoundedRectangle:
            pos: 0, 0
            size: self.width, self.height
            radius: [30]
    Label:
        text: "Nomeie a nota: "
        font_size: "20sp"
        size_hint: None, .33
        width: self.width
        pos_hint: {"x": .1, "y": .65}

    TextInput:
        id: _textinput
        background_color: 0, 0, 0, 0
        canvas.after:
            Color:
                rgba: .6, .6, .9, 1
            Line:
                points: self.x, self.y, self.x + self.width, self.y
                width: dp(1)
        multiline: False
        foreground_color: 1, 1, .8, 1
        hint_text: "Digite aqui"
        font_size: "20sp"
        size_hint: .9, .25
        pos_hint: {"center_x": .5, "y": .38}
    
    Button:
        id: _save
        background_color: 0, 0, 0, 0
        text: "Salvar"
        font_size: "20sp"
        size_hint: .4, .33
        pos_hint: {"right": 1, "y": 0}
    
    Button:
        id: _cancel
        background_color: 0, 0, 0, 0
        text: "Cancelar"
        font_size: "20sp"
        size_hint: .4, .33
        pos_hint: {"right": .6, "y": 0}
    
<FastPopup>:
    size_hint: .3, .08
    pos_hint: {"center_x": .5, "center_y": .08}
    canvas.before:
        Color:
            rgba: .2, .2, .2, 1
        RoundedRectangle:
            pos: self.x, self.y
            size: self.width, self.height
            radius: [20]
    font_size: "20sp"
    
