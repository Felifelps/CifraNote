#:kivy 1.9.0
#:import filearea view.filearea

<FileArea>:
    canvas:
        Color:
            rgba: .25, .25, .25, 0
        Rectangle:
            pos: 0, 0
            size: self.width, self.height

<FilePage>:
    title: ""
    content: ""
    textinput: _textinput
    #kivy_file_done: True
    canvas:
        Color:
            rgba: .25, .25, .25, 1
        Rectangle:
            pos: 0, 0
            size: self.width, self.height
        Color:
            rgba: 0, 0, 0, .6
        Line:
            rectangle: self.x - dp(0.5), self.y - dp(0.5), self.width + dp(1), self.height + dp(1)
            width: dp(0.5)
    
    Label:
        text: root.title
        size_hint: 1, .06
        pos_hint: {"center_x": .5, "top": 1}
        font_size: "16sp"

    FilePageTextInput:
        root: root
        id: _textinput
        text: root.content
        
<FilePageTextInput>:
    multiline: True
    size_hint: .98, .94
    pos_hint: {"center_x": .5, "y": 0}
    font_size: "16sp"
    background_color: 0, 0, 0, 0
    foreground_color: 1, 1, 1, 1
    hint_text: "Digite a cifra aqui"
