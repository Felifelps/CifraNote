#:kivy 1.9.0
#:import optionsbutton view.optionsbutton
<OptionButton>:
    background_color: 0, 0, 0, 0
    canvas.before:
        Color:
            rgba: .95, .95, .95, 1
        Rectangle:
            size: self.size
            pos: self.x, self.y
    color: 0, 0, 0, 1

<OptionsButton>:
    canvas:
        Clear
        Color:
            rgba: 1, 1, 1, 1
        Ellipse:
            size: dp(6), dp(6)
            pos: self.x + self.width/2 - dp(3), self.y + self.height*0.75  - dp(3)
        Ellipse:
            size: dp(6), dp(6)
            pos: self.x + self.width/2 - dp(3), self.y + self.height*0.5 - dp(3)
        Ellipse:
            size: dp(6), dp(6)
            pos: self.x + self.width/2 - dp(3), self.y + self.height*0.25 - dp(3)

    values: "Abrir nota", "Renomear nota", "Excluir nota", "Configurações"