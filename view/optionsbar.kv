#:kivy 1.9.0
#:import CONTROL control.control.CONTROL

<OptionsBar@RelativeLayout>:
    control: CONTROL.save_instance(self, "optionsbar")
    canvas:
        Color:
            rgba: 0.6, 0.26, .09, 1
        Rectangle:
            pos: 0, 0
            size: self.width, self.height
    Label:
        text: "[b]CifraNote[/b]"
        markup: True
        font_size: "23sp"
        pos_hint: {"x": .02, "center_y": .5}
        size_hint: .26, .9
    
    OptionsButton:
        size_hint: .1, .9
        pos_hint: {"right": .99, "center_y": .5}
    
    CreateFileButton:
        size_hint: .1, .9
        pos_hint: {"right": .89, "center_y": .5}
    
    RedoButton:
        size_hint: .1, .9
        pos_hint: {"right": .79, "center_y": .5}
    
    UndoButton:
        size_hint: .1, .9
        pos_hint: {"right": .69, "center_y": .5}
    
    FlatButton:
        size_hint: .06, .9
        pos_hint: {"right": .58, "center_y": .5}
    
    SharpButton:
        size_hint: .06, .9
        pos_hint: {"right": .52, "center_y": .5}