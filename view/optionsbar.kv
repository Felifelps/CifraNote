#:kivy 1.9.0
#:include view\actionbuttons.kv
#:import optionsbar view.optionsbar
#:import Control control.control.Control

<OptionsBar>:
    control: Control(self)
    canvas:
        Color:
            rgba: 0, 0, .6, 1
        Rectangle:
            pos: 0, 0
            size: self.width, self.height
        Color:
            rgba: 0, 0, 0, .7
        Rectangle:
            pos: 0, -20
            size: self.width, self.height + 20
    Label:
        text: "[b]CifraNote[/b]"
        markup: True
        font_size: "23sp"
        pos_hint: {"x": .02, "center_y": .5}
        size_hint: .26, .9
    
    OptionsButton:
        size_hint: .1, .9
        pos_hint: {"right": .99, "center_y": .5}
    
    CreateFileButton:
        size_hint: .1, .9
        pos_hint: {"right": .89, "center_y": .5}
    
    RedoButton:
        size_hint: .1, .9
        pos_hint: {"right": .79, "center_y": .5}
    
    UndoButton:
        size_hint: .1, .9
        pos_hint: {"right": .69, "center_y": .5}
    
    FlatButton:
        size_hint: .06, .9
        pos_hint: {"right": .59, "center_y": .5}
    
    SharpButton:
        size_hint: .06, .9
        pos_hint: {"right": .53, "center_y": .5}