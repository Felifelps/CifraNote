#:kivy 1.9.0
#:import mainpage mainpage
<SearchButton>:
    canvas:
        Clear
        Color: 
            rgba: 0, 0, 0, 1
        Line:
            circle: self.x + self.width*0.47, self.y + self.height*0.53, self.width*0.25
            width: dp(2.5)
        Line:
            points: self.x + self.width*0.66, self.y + self.height*0.34, self.x + self.width*0.8, self.y + self.height*0.2
            width: dp(2.5)

<SearchBar>:
    canvas.before:
        Color:
            rgba: 0.56, 0.56, 0.56, 1
        Rectangle:
            size: self.width, self.height
            pos: 0, 0      

<FileButton>:
    background_color: 0, 0, 0, 0
    font_size: '30sp'
    canvas.before:
        Color:
            rgba: 0.22, 0.22, 0.22, 1
        Rectangle:
            size: self.width, self.height - 2
            pos: self.x, self.y

<CreditsButton>:
    background_color: 0, 0, 0, 0 #invisibles
    font_size: '20sp'
    text: "Sobre"
    size_hint: None, None
    size: dp(80), dp(40)
    canvas.before:
        Color:
            rgba: 0.56, 0.56, 0.56, .8
        RoundedRectangle:
            size: self.size
            pos: self.x, self.y
            radius: [20,]

<CreateFileButton>:
    x_reference: 100
    y_reference: 100
    size_hint: None, None
    size: dp(100), dp(100)
    pos: self.x_reference*0.7, self.y_reference*0.04
    canvas:
        Clear
        Color: 
            rgba: .88, .88, .88, 1
        Ellipse:
            pos: self.x_reference*0.7, self.y_reference*0.04
            size: dp(100), dp(100)
        Color: 
            rgba: 1, 1, 1, 1
        Line:
            points: self.x + self.width/2, self.y + 20, self.x + self.width/2, self.y + self.height - 20
            width: dp(5)
        Line:
            points: self.x + 20, self.y + self.height/2, self.x + self.width - 20, self.y + self.height/2 
            width: dp(5)

<MainPageModel@RelativeLayout>:
    filebuttons: fbs
    canvas:
        Color:
            rgba: 0, 0, 0, 1
        Rectangle:
            size: self.width, self.height
            pos: self.x, self.y

    Label:
        canvas.before:
            Color:
                rgba: 0.22, 0.22, 0.22, 1
            Rectangle:
                size: self.width, self.height
                pos: self.x, self.y
            Color:
                rgba: 0, 0, 0, 0.5
            Rectangle:
                size: self.width, 20
                pos: self.x, self.y - 20
        text: "CifraNote"
        color: 1, 1, 1, 1
        font_size: '80sp'
        size_hint: 1, .120
        pos_hint: {"x": 0, "y": .88}
    
    SearchBar:
        root: root
        size_hint: 1, .095
        pos_hint: {"x": 0, "y": .785}
    
    FileButtons:
        id: fbs
        root: root
        size: self.size
        pos_hint: {"top": .785, "x": 0}
        size_hint: 1, .785
    
    CreateFileButton:
        root: root
        x_reference: root.width
        y_reference: root.height
    
    CreditsButton:
        root: root
        pos_hint: {'center_x': .175, 'center_y': .105}

<MainPage>:
    name: 'mainpage'
    model: model
    MainPageModel:
        id: model
        root: root
    