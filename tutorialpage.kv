#:kivy 1.9.0
#:import tutorialpage tutorialpage

<Back@Button>:
    canvas:
        Clear
        Color: 
            rgba: 0, 0, 0, 1
        Line:
            points: self.x + self.width, self.y + self.height, self.x, self.y + self.height/2, self.x + self.width, self.y
            width: dp(5) 

<TutorialPage>:
    name: 'tutorialpage'
    TutorialPageModel:
        root: root

<TutorialPageModel@RelativeLayout>:
    Label:
        canvas.before:
            Color:
                rgba: 0.56, 0.56, 0.56, 1
            Rectangle:
                size: self.width, self.height
                pos: self.x, self.y
            Color:
                rgba: 0, 0, 0, 0.5
            Rectangle:
                size: self.width, 20
                pos: self.x, self.y - 20
        text: "Tutorial"
        color: 1, 1, 1, 1
        font_size: '60sp'
        size_hint: 1, .1
        pos_hint: {"x": 0, "y": .9}
    
    Back:
        pos_hint: {"x":.025, "center_y": .95}
        size_hint: None, .05
        width: root.height*0.05
        on_press: root.back_to_mainpage()
    
    ScrollView:
        size_hint: .98, .9
        pos_hint: {"center_x": .5, "top": .9}
        do_scroll_y: True
        do_scroll_x: False
        Label:
            text: root.tutorial_text
            font_size: '25sp'
            foreground_color: 1, 1, 1, 0
            size_hint_y: None
            height: self.texture_size[1]
            text_size: self.width, None


        